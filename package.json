{
  "name": "openspec-vscode",
  "displayName": "OpenSpec",
  "description": "Visual dashboard and interactive UI for OpenSpec workflows",
  "version": "0.1.0",
  "publisher": "openspec",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "openspec",
    "spec-driven",
    "workflow",
    "dashboard",
    "task management"
  ],
  "activationEvents": [
    "workspaceContains:openspec/config.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openspec.openDashboard",
        "title": "OpenSpec: Open Dashboard",
        "category": "OpenSpec"
      },
      {
        "command": "openspec.refreshData",
        "title": "OpenSpec: Refresh Data",
        "category": "OpenSpec",
        "icon": "$(refresh)"
      },
      {
        "command": "openspec.newChange",
        "title": "OpenSpec: Create New Change",
        "category": "OpenSpec"
      },
      {
        "command": "openspec.archiveChange",
        "title": "OpenSpec: Archive Change",
        "category": "OpenSpec"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "pnpm run compile && pnpm run build:webview",
    "build:webview": "vite build",
    "dev:webview": "vite",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.3",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
